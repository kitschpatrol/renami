{
	"name": "@kitschpatrol/renami",
	"version": "0.1.0",
	"description": "A CLI tool and TypeScript library for config-driven and content-aware automatic filename management.",
	"keywords": [
		"rename",
		"filename",
		"cli",
		"npm-package"
	],
	"homepage": "https://github.com/kitschpatrol/renami",
	"bugs": "https://github.com/kitschpatrol/renami/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/renami.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/lib/index.d.ts",
			"import": "./dist/lib/index.js"
		}
	},
	"main": "./dist/lib/index.js",
	"module": "./dist/lib/index.js",
	"types": "./dist/lib/index.d.ts",
	"bin": {
		"renami": "dist/bin/cli.js"
	},
	"files": [
		"dist/*"
	],
	"scripts": {
		"build": "tsdown",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"coverage": "vitest run --coverage",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"release": "bumpp --commit 'Release: %s' && pnpm run build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') && pnpm publish",
		"test": "vitest run"
	},
	"dependencies": {
		"@sindresorhus/is": "^7.2.0",
		"@stdlib/assert-is-absolute-path": "^0.2.3",
		"@types/mdast": "^4.0.4",
		"cosmiconfig": "^9.0.1",
		"cosmiconfig-typescript-loader": "^6.2.0",
		"date-fns": "^4.1.0",
		"date-fns-tz": "^3.2.0",
		"deepmerge-ts": "^7.1.5",
		"escape-string-regexp": "^5.0.0",
		"filenamify": "~6.0.0",
		"github-slugger": "^2.0.0",
		"globby": "^16.2.0",
		"mdast-util-to-string": "^4.0.0",
		"nanoid": "^5.1.7",
		"natural-orderby": "^5.0.0",
		"numerable": "^0.3.15",
		"pathe": "^2.0.3",
		"picocolors": "^1.1.1",
		"pretty-ms": "^9.3.0",
		"property-expr": "^2.0.6",
		"remark-frontmatter": "^5.0.0",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"unified": "^11.0.5",
		"unist-util-select": "^5.1.0",
		"vfile": "^6.0.3",
		"vfile-matter": "^5.0.1",
		"yargs": "^18.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^7.1.0",
		"@types/node": "^20.19.39",
		"@types/yargs": "^17.0.35",
		"@vvo/tzdb": "^6.198.0",
		"bumpp": "^11.0.1",
		"mdat-plugin-cli-help": "^2.1.1",
		"tsdown": "^0.21.7",
		"typescript": "~5.9.3",
		"vitest": "^4.1.2"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=20.19.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=22.18.0"
		}
	},
	"publishConfig": {
		"access": "public"
	}
}
