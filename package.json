{
	"name": "renami",
	"version": "1.0.0",
	"description": "A CLI tool and TypeScript library for config-driven automatic filename management.",
	"keywords": [
		"rename",
		"filename",
		"cli",
		"npm-package"
	],
	"homepage": "https://github.com/kitschpatrol/renami",
	"bugs": "https://github.com/kitschpatrol/renami/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/renami.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/lib/index.js",
			"types": "./dist/lib/index.d.ts"
		}
	},
	"main": "./dist/lib/index.js",
	"module": "./dist/lib/index.js",
	"types": "./dist/lib/index.d.ts",
	"bin": {
		"renami": "dist/bin/cli.js"
	},
	"files": [
		"dist/*"
	],
	"scripts": {
		"build": "pkgroll --clean-dist --tsconfig tsconfig.build.json",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"coverage": "vitest run --coverage",
		"fix": "kpi fix",
		"lint": "kpi lint",
		"release": "bumpp --commit 'Release: %s' && pnpm run build && pnpm publish --otp $(op read 'op://Personal/Npmjs/one-time password?attribute=otp')",
		"test": "vitest"
	},
	"dependencies": {
		"@types/node": "^20.17.24",
		"@types/yargs": "^17.0.33",
		"chalk": "^5.4.1",
		"yargs": "^17.7.2"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^5.3.1",
		"@stdlib/assert-is-absolute-path": "^0.2.2",
		"bumpp": "^10.1.0",
		"deepmerge-ts": "^7.1.5",
		"filenamify": "^6.0.0",
		"nanoid": "^5.1.3",
		"path-browserify-esm": "^1.0.6",
		"pkgroll": "^2.11.2",
		"pretty-ms": "^9.2.0",
		"slash": "^5.1.0",
		"typescript": "~5.7.3",
		"untildify": "^5.0.0",
		"vitest": "^3.0.8"
	},
	"packageManager": "pnpm@10.6.2",
	"engines": {
		"node": "^18.15.0 || >=20.11.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"puppeteer"
		]
	}
}
